# ----------------------------------------------------------------
# Database (required for both web and worker)
# ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/market_radar_pl

# Supabase (use instead of a raw DATABASE_URL if you use Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------
# Web (Next.js) — public vars exposed to the browser
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------------
# Worker — scrape behaviour
# ----------------------------------------------------------------

# How many milliseconds between full scrape cycles (default: 15 min)
WORKER_INTERVAL_MS=900000

# Consecutive missing checks before a listing is marked probably_gone
GONE_THRESHOLD=2

# Seconds to wait between requests to the same domain (politeness)
FETCH_DELAY_SECONDS=10

# Max concurrent fetches across all domains
FETCH_CONCURRENCY=2

# User-agent string sent with every request
FETCH_USER_AGENT=Mozilla/5.0 (compatible; MarketRadarBot/1.0; +https://example.com/bot)

# ----------------------------------------------------------------
# Adapter feature flags (worker only)
# Set to "true" to enable — disabled by default for the MVP demo
# ----------------------------------------------------------------
OLX_ENABLED=false
ALLEGRO_ENABLED=false
