# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/market_radar_pl

# Supabase (alternative to direct Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Worker
WORKER_INTERVAL_MS=900000
# How many consecutive missing checks before marking probably_gone
GONE_THRESHOLD=2

# Web (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Fetcher
# Seconds between requests to the same domain (rate limiting)
FETCH_DELAY_SECONDS=3
# Max concurrent requests
FETCH_CONCURRENCY=2
# User-agent string (use a real browser UA)
FETCH_USER_AGENT=Mozilla/5.0 (compatible; MarketRadarBot/1.0; +https://example.com/bot)
